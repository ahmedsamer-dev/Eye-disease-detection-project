modules = ["dotnet-7.0", "python-3.12", "dotnet-8.0", "nodejs-22"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Model Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd AI-Eye-Diagnosis-main && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Hassan_EyeDiseaseAI-master/EyeDiseaseAI.API && dotnet run --launch-profile http"
waitForPort = 8000

[[workflows.workflow]]
name = "AI Model Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Hassan_EyeDiseaseAI-master/AiModelServer && python app.py"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[[ports]]
localPort = 8080
externalPort = 8080
exposeLocalhost = true

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd Hassan_EyeDiseaseAI-master/AiModelServer && python app.py & cd Hassan_EyeDiseaseAI-master/EyeDiseaseAI.API && dotnet run --launch-profile http & cd AI-Eye-Diagnosis-main && npm run build && npx serve -s dist -l 5000"]
build = ["bash", "-c", "cd AI-Eye-Diagnosis-main && npm install && npm run build"]
